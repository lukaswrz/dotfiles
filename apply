#!/usr/bin/env oil

if (len(ARGV) < 1) {
    write 'No setup has been provided.' >&2
    exit 1
}

var mode = null
if (Int($(id --user)) === 0) {
    setvar mode = 'system'
} else {
    setvar mode = 'user'
}

for setup in @ARGV {
    var files_file = "setup/$setup/files/$mode"
    if test --file $files_file {
        while read --line :line {
            if (line !~ / %start (('#' dot*) | (space*)) %end /) {
                cd -- $mode {
                    for file in @glob(line) {
                        if test --file $file {
                            mkdir --verbose --parents -- $(dirname -- ~/$file)
                            if (mode === 'system') {
                                cp --verbose --force -- $file ~/$file
                            } else {
                                ln --verbose --force --symbolic -- $PWD/$file ~/$file
                            }
                        }
                    }
                }
            }
        } < $files_file
    }

    var units_file = "setup/$setup/units/$mode"
    if test --file $units_file {
        var units = []
        while read --line :line {
            if (line !~ / %start (('#' dot*) | (space*)) %end /) {
                setvar units = units ++ [line]
            }
        } < $units_file
        systemctl --$mode enable --now -- @units
    }
}
