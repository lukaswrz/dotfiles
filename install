#!/usr/bin/env oil

if (len(ARGV) < 1) {
    write 'No setup has been provided.' >&2
    exit 1
}

for setup in @ARGV {
    var packages_file = "setup/$setup/packages"
    var packages = []
    while read --line :line {
        if (line !~ / %start (('#' dot*) | (space*)) %end /) {
            setvar packages = packages ++ [line]
        }
    } < $packages_file
    yay -S --needed --noconfirm -- @packages
}
